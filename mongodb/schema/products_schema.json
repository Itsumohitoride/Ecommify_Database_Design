{
  "collection": "products",
  "engine": "MongoDB",
  "description": "Catálogo enriquecido de productos con especificaciones variables por categoría. Esquema flexible.",
  "schema_validation": {
    "$jsonSchema": {
      "bsonType": "object",
      "required": ["product_id", "category_name", "name", "created_at", "updated_at"],
      "properties": {
        "product_id": { "bsonType": "string", "description": "Hash MD5, FK a PostgreSQL product.product_id" },
        "category_name": { "bsonType": "string", "description": "Categoría en portugués" },
        "category_name_english": { "bsonType": "string", "description": "Traducción al inglés" },
        "name": { "bsonType": "string", "description": "Nombre del producto (anonimizado por Olist)" },
        "description": { "bsonType": "string" },
        "photo_urls": { "bsonType": "array", "items": { "bsonType": "string" }, "description": "URLs del CDN" },
        "specifications": { "bsonType": "object", "description": "Atributos variables por categoría. Sin estructura fija." },
        "tags": { "bsonType": "array", "items": { "bsonType": "string" } },
        "avg_review_score": { "bsonType": "double", "minimum": 0, "maximum": 5 },
        "total_reviews": { "bsonType": "int", "minimum": 0 },
        "schema_version": { "bsonType": "int", "description": "Versionado de esquema para migraciones graduales" },
        "created_at": { "bsonType": "date" },
        "updated_at": { "bsonType": "date" }
      }
    }
  },
  "indexes": [
    { "key": { "product_id": 1 }, "unique": true, "description": "Clave de sincronización con PostgreSQL" },
    { "key": { "category_name": 1 }, "description": "Filtro por categoría" },
    { "key": { "tags": 1 }, "description": "Búsqueda por tags" },
    { "key": { "avg_review_score": -1 }, "description": "Ordenar por calificación" },
    { "key": { "created_at": -1 }, "description": "Productos recientes" },
    { "key": { "name": "text", "description": "text", "category_name": "text" }, "options": { "default_language": "none" }, "description": "Búsqueda full-text" }
  ]
}
